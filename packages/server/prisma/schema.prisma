generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               Int              @id @default(autoincrement())
  name             String           @unique      // 用户名
  email            String           @unique      // 邮箱
  password         String                          // bcrypt 哈希
  notes            Note[]
  recentActivities RecentActivity[]
  noteVersions     NoteVersion[]
  aiUsageLogs      AIUsageLog[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  tags      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  isFavorite Boolean @default(false)
  versions      NoteVersion[]
  currentVersion Int @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model RecentActivity {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  type        String   // 'dashboard', 'note', 'idea', 'tool'
  title       String
  description String
  icon        String?  // 图标名称（lucide图标）
  resourceId  Int?     // 关联的资源ID（笔记ID、灵感ID等）
  createdAt   DateTime @default(now())
}

model NoteVersion {
  id          Int      @id @default(autoincrement())
  noteId      Int
  note        Note     @relation(fields: [noteId], references: [id])
  title       String
  content     String
  tags        String   // 逗号分隔的标签字符串
  version     Int      // 版本号，从1开始递增
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([noteId, version])  // 确保每个笔记的版本号唯一
}


// AI 使用日志
model AIUsageLog {
  id          Int      @id @default(autoincrement())
  task        String   // 任务类型：finance-parse, daily-briefing, study-summary, exercise-recommend, general-chat
  provider    String   // AI 提供商：openai, anthropic, huggingface, local, fallback
  inputLength Int      // 输入长度
  success     Boolean  // 是否成功
  latency     Int      // 延迟（毫秒）
  error       String?  // 错误信息（如果失败）
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([provider, task])
}